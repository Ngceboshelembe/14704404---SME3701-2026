%% Declaring known Variables
m = 5;              % Mass (kg)
k = 2000;           % Spring stiffness (N/m)
x0 = 0.02;          % Initial displacement (m)
v0 = 0;             % Initial velocity (m/s)

>> %% 1.2 Natural Angular Frequency(wn)
%wn: wn = sqrt(k/m)
wn = sqrt(k/m);     
fprintf('Natural angular frequency (wn) = %.2f rad/s\n', wn); % %.2f is placement holder for value (wn)
Natural angular frequency (wn) = 20.00 rad/s
>> t = linspace(0, 5, 1000);

>> %% 1.2 Displacement calculation (x(t)) % Oscillation from max displacement and 0 velocity
% Equation: x(t) = x0 * cos(wn * t) 
% Since initial velocity is zero, cosine formular is used
x = x0 * cos(wn * t);

>> 
>> %% 1.3 Plot displacement vs time
figure;
plot(t, x, 'b', 'LineWidth', 2);  % time vs displacement graph with thick '2' blue 'b' line and grid
xlabel('Time (s)');
ylabel('Displacement (m)');
title('Displacement vs Time for Undamped System');
grid on;

>> 
>> %% 1.4 Velocity calculation
% Velocity is the derivative of displacement:
% v(t) = dx/dt = -x0 * wn * sin(wn * t)
v = -x0 * wn * sin(wn * t);

%% Plot velocity vs time
figure;
plot(t, v, 'r', 'LineWidth', 2); % time vs velocity graph with thick '2' red 'r' line and grid
xlabel('Time (s)');
ylabel('Velocity (m/s)');
title('Velocity vs Time for Undamped System');
grid on;
>> 
